+        renderRecentComplaints: function(complaints) {
+          const container = document.getElementById('recent-complaints-container');
+          if (!container) return;
+          
+          container.innerHTML = '';
+          
+          if (!complaints || complaints.length === 0) {
+            container.innerHTML = '<p class="text-sm text-gray-500 text-center py-3">선택 기간 내 민원이 없습니다.</p>';
+            return;
+          }
+          
+          complaints.forEach((complaint, index) => {
+            const statusColors = {
+              '완료': 'bg-green-100 text-green-800',
+              '진행중': 'bg-blue-100 text-blue-800',
+              '보류': 'bg-yellow-100 text-yellow-800',
+              '대기': 'bg-gray-100 text-gray-800'
+            };
+            
+            const statusColor = statusColors[complaint.status] || 'bg-gray-100 text-gray-800';
