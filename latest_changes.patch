+                </div>
+                <div class="flex items-start gap-2">
+                  <i class="fas fa-wrench text-xs text-gray-400 mt-1"></i>
+                  <span class="text-sm text-gray-600">${complaint.action}</span>
+                </div>
+              </div>
+            `;
+            container.appendChild(complaintCard);
